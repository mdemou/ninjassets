# Infrastructure connection for E2E tests (PostgreSQL + Redis).
# Must match your local Docker Compose or host Postgres/Redis.
# Playwright overrides ports, DB name, and mock flags when starting test servers.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/ninjasset_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_password
