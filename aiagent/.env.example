# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

# ── Internal auth (backend → aiagent) ────────────────────────────────────────
# Shared secret; the backend sends it as the `X-Internal-Key` header.
# Leave empty in local dev to disable the check.
AI_AGENT_API_KEY=

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# ── Embeddings (local multilingual-e5) ───────────────────────────────────────
EMBEDDING_MODEL_HF=intfloat/multilingual-e5-base
EMBEDDING_DIMENSIONS=768
# cpu | cuda | mps (Apple Silicon)
EMBEDDING_DEVICE=cpu
# HuggingFace cache dir — mount as a volume in dev so the ~1.1 GB model persists.
HF_HOME=

# ── LLM (Grok / xAI) ─────────────────────────────────────────────────────────
GROK_API_KEY=changeme
GROK_MODEL=grok-2-latest

# ── RAG ──────────────────────────────────────────────────────────────────────
TOP_K=5
MIN_SCORE=0.0
MAX_HISTORY_MESSAGES=6

# ── PII anonymization (Presidio) ─────────────────────────────────────────────
PII_ENABLED=true
PRESIDIO_SPACY_MODEL_EN=en_core_web_sm
PRESIDIO_SPACY_MODEL_ES=es_core_news_md

# ── Indexing / bootstrap ─────────────────────────────────────────────────────
# On startup: create the collection if missing; if it is empty, run the indexer.
AI_AUTO_INDEX_ON_START=false
# Source locations (paths are resolved relative to CORPUS_ROOT).
CORPUS_ROOT=..
SPECS_GLOB=docs/spec-*.md
DOCS_PAGES_FILE=frontend/app/data/docs-pages.ts
# Generated offline by the backend (`npm run export:openapi`) — no running server needed.
OPENAPI_FILE=docs/openapi.json

# ── Tracing (OPTIONAL — off unless both keys are set) ─────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
