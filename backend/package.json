{
  "name": "ninjasset-backend",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "tsx watch -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node -r dotenv/config dist/main.js",
    "migrate": "tsx node_modules/.bin/knex migrate:latest --knexfile knexfile.cjs",
    "migrate:rollback": "tsx node_modules/.bin/knex migrate:rollback --knexfile knexfile.cjs",
    "seed": "tsx migrations/seeds/seed-dev-data.ts",
    "seed:demo": "tsx migrations/seeds/seed-dev-data.ts --reset",
    "seed:rollback": "tsx migrations/seeds/seed-dev-data.ts --rollback",
    "migrate:make": "node scripts/migrate-make.cjs",
    "export:openapi": "tsx -r dotenv/config -r tsconfig-paths/register scripts/export-openapi.ts",
    "db:dev": "docker compose -f ../docker-compose.yml --env-file .env up -d",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hapi/boom": "^10.0.0",
    "@hapi/hapi": "^21.3.0",
    "@hapi/inert": "^7.1.0",
    "@hapi/vision": "^7.0.3",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "hapi-auth-jwt2": "^11.0.0",
    "hapi-swagger": "^17.3.2",
    "ioredis": "^5.11.0",
    "joi": "17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.0",
    "pino": "10.3.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.1"
  }
}
