# Database connection - you can use either DATABASE_URL or individual DB_* variables
# DATABASE_URL is still needed for knex migrations and docker-compose
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ninjasset_dev

# Individual database connection parameters (preferred for application config)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ninjasset_dev
JWT_ADMIN_SECRET_KEY=admin-secret-dev
JWT_USER_SECRET_KEY=user-secret-dev
RECAPTCHA_SECRET_KEY=
MOCK_CAPTCHA=false

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_password
REDIS_DB=0
# Unified notification job queue (webhooks + mandatory emails; SPEC-WEBHOOK-001 §7)
REDIS_NOTIFICATIONS_QUEUE=ninjasset:notifications
REDIS_NOTIFICATIONS_PROCESSING_QUEUE=ninjasset:notifications:processing
# Import/export job queue (optional low-latency wakeup; SPEC-IMPORT-001 D-IMPORT-2)
REDIS_IMPORT_EXPORT_QUEUE=ninjasset:import-export
# Pipeline master switch (independent of WEBHOOKS_ENABLED so emails are never stopped by it)
NOTIFICATIONS_ENABLED=true
# At-least-once tuning: dedup TTL, reaper cadence, visibility timeout, retry cap, block
NOTIFICATIONS_DEDUP_TTL_SEC=86400
NOTIFICATIONS_DEDUP_PREFIX=ninjasset:notif:dedup:
NOTIFICATIONS_REAPER_INTERVAL_MS=15000
NOTIFICATIONS_VISIBILITY_TIMEOUT_MS=60000
NOTIFICATIONS_MAX_RETRIES=5
NOTIFICATIONS_BLOCK_SECONDS=5

# Email (SMTP) — leave SMTP_HOST empty to log emails to console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
MOCK_EMAIL=false

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Self-service registration (set to false to disable signup)
SIGNUP_ENABLED=true

# Directories where uploaded images are stored on disk
AVATAR_STORAGE_PATH=./uploads/avatars
ASSET_IMAGE_STORAGE_PATH=./uploads/asset-images
MANUFACTURER_IMAGE_STORAGE_PATH=./uploads/manufacturer-images
VENDOR_IMAGE_STORAGE_PATH=./uploads/vendor-images

# Custody receipt documents (printable PDF + signed upload, SPEC-CUSTODY-DOC-001)
# Signed PDFs are stored as raw bytes (no image pipeline), separate from images.
CUSTODY_DOCUMENT_STORAGE_PATH=./uploads/custody-documents
# Max upload size for a signed custody PDF (bytes). Default 10 MB.
CUSTODY_DOCUMENT_MAX_BYTES=10485760
# Organization name printed on the generated receipt header (defaults to the app name)
CUSTODY_ORG_NAME=ninjasset
# Optional logo image path for the receipt header (leave empty to omit)
CUSTODY_ORG_LOGO_PATH=

# Token expiry (hours)
EMAIL_VERIFICATION_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1
HANDOVER_TOKEN_EXPIRY_HOURS=72

# Account lockout
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# Webhooks (Slack/Discord/Telegram outbound notifications, SPEC-WEBHOOK-001)
WEBHOOKS_ENABLED=true
WEBHOOK_HTTP_TIMEOUT_MS=5000
# SSRF allowlists (comma-separated hostnames). Telegram uses a fixed API base.
WEBHOOK_ALLOWED_SLACK_HOSTS=hooks.slack.com
WEBHOOK_ALLOWED_DISCORD_HOSTS=discord.com,discordapp.com,ptb.discord.com,canary.discord.com
WEBHOOK_TELEGRAM_API_BASE=https://api.telegram.org
# Set true ONLY in dev/test to allow http/loopback targets (e.g. a local mock receiver)
WEBHOOK_ALLOW_INSECURE_TARGETS=false
# Interval (ms) for the periodic data-quality alert.raised scan (scheduler task `data-quality-scan`)
WEBHOOK_ALERT_SCAN_INTERVAL_MS=3600000

# Redis-backed periodic scheduler (token cleanup, API log retention, notification reaper, etc.)
MAINTENANCE_TICK_MS=5000
MAINTENANCE_LOCK_TTL_SEC=300
MAINTENANCE_KEY_PREFIX=ninjasset:sched:
TOKEN_CLEANUP_INTERVAL_MS=21600000
API_RETENTION_PURGE_INTERVAL_MS=21600000
IMPORT_ARTIFACT_PURGE_INTERVAL_MS=21600000

# Bulk import/export (admin hub, SPEC-IMPORT-001)
# Master switch for the in-process worker (set false on API nodes when running a separate worker)
IMPORT_EXPORT_ENABLED=true
# Disk root for uploaded source files and generated artifacts (exports, error reports)
IMPORT_STORAGE_PATH=./uploads/import-export
# Upload cap (bytes) and row cap per job
IMPORT_MAX_FILE_BYTES=20971520
IMPORT_MAX_ROWS=50000
# Auto-delete artifacts after this many days
IMPORT_ARTIFACT_RETENTION_DAYS=7
# BLPOP block (seconds) for the event-driven import/export consumer
IMPORT_WORKER_BLOCK_SECONDS=5
# Scheduler safety sweep when Redis was down (ms); also drains stale queued jobs
IMPORT_SAFETY_SWEEP_MS=30000
# Email admin when a long job completes (default off in dev)
IMPORT_EXPORT_NOTIFY_ON_COMPLETE=false

# API keys and machine access (SPEC-API-001)
API_KEY_PREFIX=nsk_live_
API_KEY_DEFAULT_TTL_DAYS=0
API_KEY_LAST_USED_THROTTLE_SEC=60
API_ACCESS_LOG_RETENTION_DAYS=90
API_IDEMPOTENCY_TTL_HOURS=24

# Server
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
ADMIN_PAGE_SIZE=20

# Asset QR codes (GET /api/p/assets/{id}/qr)
ASSET_QR_PNG_SIZE=512